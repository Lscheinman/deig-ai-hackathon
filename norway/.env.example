# JONE Agent Configuration
# Copy this file to .env and fill in your credentials

# =====================================================
# SAP HANA Cloud Connection
# =====================================================
HANA_HOST=your-hana-instance.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=your_hana_user
HANA_PASSWORD=your_hana_password

# HANA runtime flags (defaults work for most setups)
HANA_ENCRYPT=true
HANA_SSL_VALIDATE=false
HANA_AUTOCOMMIT=true

# =====================================================
# SAP AI Core / GenAI Hub (for LLM)
# =====================================================
# Leave blank to use heuristic fallback mode (no LLM)
AICORE_CLIENT_ID=
AICORE_CLIENT_SECRET=
AICORE_AUTH_URL=https://your-subdomain.authentication.region.hana.ondemand.com/oauth/token
AICORE_BASE_URL=https://api.ai.prod.region.ml.hana.ondemand.com/v2
AICORE_RESOURCE_GROUP=default

# Chat model to use (default: gpt-4o)
AICORE_CHAT_MODEL=gpt-4o

# =====================================================
# JONE Agent Configuration
# =====================================================
# Target schema for HR data
JONE_TARGET_SCHEMA=DFS_HR

# Graph tables (Norwegian skills/tasks/qualities)
JONE_NODES_TABLE=SKILLS_AND_QUALS_NODES_NOR
JONE_EDGES_TABLE=SKILLS_AND_QUALS_EDGES_NOR

# Graph workspace
JONE_GRAPH_SCHEMA=DFS_HR
JONE_GRAPH_WORKSPACE=GW_SKILLS

# Query limits
JONE_MAX_LIMIT=200
JONE_DEFAULT_LIMIT=50

# =====================================================
# Application Settings
# =====================================================
APP_NAME=JONE Agent
DEBUG=false
ALLOW_ORIGINS=*

# Server settings (used by run.py)
HOST=0.0.0.0
PORT=8080

# =====================================================
# Sports One Integration (for drill-down URLs)
# =====================================================
SPORTS_ONE_BASE=https://s1-test-patch-publicsafety.test.sportsone.cloud.sap/sap/sports/fnd/ui/start/index.html
SPORTS_ONE_PLAYER_PATH=#/content/player//
SPORTS_ONE_TEAM_PATH=#/content/ownclub/teams/
SPORTS_ONE_CLUB_PATH=#/content/ownclub/teams/
SPORTS_ONE_DEFAULT_CLUB_ID=0AABAF10128438A318008BDE3E08B104
